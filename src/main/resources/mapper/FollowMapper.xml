<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.cookiemusicdemo.mapper.FollowMapper">

    <resultMap id="BaseResultMap" type="com.example.cookiemusicdemo.model.domain.Follow">
        <id column="id" property="id" jdbcType="BIGINT" />
        <result column="user_id" property="userId" jdbcType="INTEGER" />
        <result column="follow_user_id" property="followUserId" jdbcType="INTEGER" />
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP" />
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, follow_user_id, create_time
    </sql>

    <select id="selectFollowingIds" resultType="java.lang.Integer">
        SELECT follow_user_id
        FROM follow
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <select id="selectFollowerIds" resultType="java.lang.Integer">
        SELECT user_id
        FROM follow
        WHERE follow_user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <select id="selectFollowingUsers" resultType="java.util.HashMap">
        SELECT c.id, c.username, c.avator
        FROM follow f
        INNER JOIN consumer c ON c.id = f.follow_user_id
        WHERE f.user_id = #{userId}
        ORDER BY f.create_time DESC
    </select>

    <select id="selectFollowerUsers" resultType="java.util.HashMap">
        SELECT c.id, c.username, c.avator
        FROM follow f
        INNER JOIN consumer c ON c.id = f.user_id
        WHERE f.follow_user_id = #{userId}
        ORDER BY f.create_time DESC
    </select>

</mapper>

